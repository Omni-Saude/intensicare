# =============================================================================
# Intensicare — .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
sdist/
*.whl
*.egg-info
.eggs/
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/
ENV/
.envrc

# ---------------------------------------------------------------------------
# Environment & Secrets
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.p12
*.pfx
credentials.json
secrets.yaml
.secrets.baseline

# ---------------------------------------------------------------------------
# IDE & Editor
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-*
.DS_Store
Thumbs.db
*.iml
.gradle/

# ---------------------------------------------------------------------------
# Testing & Coverage
# ---------------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.tox/
.nox/
*.cover
.mypy_cache/
.ruff_cache/
.dmypy.json
dmypy.json

# ---------------------------------------------------------------------------
# Jupyter
# ---------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb
.jupyter/

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
docker-compose.override.yml
.docker/

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
alembic/versions/*.pyc

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
*.log.*
logs/

# ---------------------------------------------------------------------------
# OS
# ---------------------------------------------------------------------------
.DS_Store
Desktop.ini
ehthumbs.db
Icon?
._*

# ---------------------------------------------------------------------------
# Terraform (infra como código — apenas para referência futura)
# ---------------------------------------------------------------------------
.terraform/
terraform.tfstate
terraform.tfstate.backup
*.tfvars
*.tfstate
*.tfstate.*
crash.log
override.tf
override.tf.json
.terraform.lock.hcl

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
*.orig
*.bak
tmp/
temp/
frontend-v2/node_modules/
frontend-v2/.next/
frontend-v2/storybook-static/
*.tsbuildinfo
