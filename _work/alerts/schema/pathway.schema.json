{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://intensicare.io/schemas/pathway.schema.json",
  "title": "Trilhas Engine — Pathway Definition Schema",
  "description": "JSON Schema v7 for declarative pathway YAML definitions per ADR-0020.",
  "type": "object",
  "required": ["pathway", "evaluation", "criteria", "states"],
  "additionalProperties": false,
  "properties": {
    "pathway": {
      "type": "object",
      "description": "Pathway identity and metadata.",
      "required": ["id", "name", "slug", "version", "content_hash"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "integer",
          "minimum": 1,
          "description": "Unique pathway identifier."
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable pathway name."
        },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
          "description": "URL-safe identifier slug."
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
          "description": "Semantic version string."
        },
        "content_hash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$",
          "description": "SHA-256 content hash of this definition (content-addressed per ADR-021)."
        },
        "description": {
          "type": "string",
          "description": "Optional human-readable description."
        },
        "active": {
          "type": "boolean",
          "default": true,
          "description": "Whether this pathway is active."
        }
      }
    },
    "evaluation": {
      "type": "object",
      "description": "Evaluation configuration.",
      "required": ["mode", "inputs"],
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["micro-batch", "near-real-time", "hybrid"],
          "description": "Evaluation mode: micro-batch (batch polls), near-real-time (event-driven), hybrid (both)."
        },
        "inputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "source", "unit"],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1,
                "description": "Input variable name."
              },
              "source": {
                "type": "string",
                "minLength": 1,
                "description": "Data source identifier (e.g., amh_gold, vitals_stream)."
              },
              "unit": {
                "type": "string",
                "minLength": 1,
                "description": "Canonical unit string (must resolve in units registry)."
              },
              "description": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "category", "predicate"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^crit-[a-z0-9-]+$",
            "description": "Unique criterion identifier."
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "Human-readable criterion name."
          },
          "category": {
            "type": "string",
            "minLength": 1,
            "description": "Clinical category (e.g., oxigenacao, hemodinamica)."
          },
          "description": {
            "type": "string"
          },
          "predicate": {
            "type": "object",
            "required": ["type", "input", "unit"],
            "additionalProperties": false,
            "properties": {
              "type": {
                "type": "string",
                "enum": ["threshold", "graded", "boolean", "composite", "temporal"],
                "description": "Predicate type: threshold (single comparison), graded (bands), boolean (true/false), composite (AND/OR/NOT of sub-predicates), temporal (precomputed duration vs. budget: within/overdue)."
              },
              "input": {
                "type": "string",
                "minLength": 1,
                "description": "Reference to evaluation.inputs[].name."
              },
              "unit": {
                "type": "string",
                "minLength": 1,
                "description": "Canonical unit string (must resolve in units registry)."
              },
              "bands": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["range", "severity", "score"],
                  "additionalProperties": false,
                  "properties": {
                    "range": {
                      "type": "array",
                      "minItems": 2,
                      "maxItems": 2,
                      "items": [
                        {"type": "number"},
                        {"type": ["number", "null"]}
                      ],
                      "description": "Inclusive lower bound, exclusive upper bound. null = infinity."
                    },
                    "severity": {
                      "type": "string",
                      "enum": ["normal", "watch", "urgent", "critical"],
                      "description": "CON-SEED-11 canonical severity level."
                    },
                    "score": {
                      "type": "integer",
                      "minimum": 0,
                      "description": "Numerical score for this band."
                    },
                    "label": {
                      "type": "string",
                      "description": "Optional human-readable band label."
                    }
                  }
                }
              },
              "operator": {
                "type": "string",
                "enum": [">=", "<=", ">", "<", "==", "!="],
                "description": "Comparison operator (for threshold type)."
              },
              "value": {
                "description": "Threshold value (for threshold type)."
              },
              "sub_predicates": {
                "type": "array",
                "items": {"$ref": "#/properties/criteria/items/properties/predicate"},
                "description": "Sub-predicates for composite type (AND/OR)."
              },
              "combinator": {
                "type": "string",
                "enum": ["AND", "OR", "NOT"],
                "description": "Combinator for composite predicates. NOT requires exactly one sub_predicate and negates its result."
              },
              "negate": {
                "type": "boolean",
                "description": "For boolean predicates: invert the truthiness result (met = NOT bool(value)). Optional, default false."
              },
              "within_minutes": {
                "type": "integer",
                "minimum": 0,
                "description": "For temporal predicates: the budget in minutes to compare the input duration against."
              },
              "satisfied_when": {
                "type": "string",
                "enum": ["within", "overdue"],
                "description": "For temporal predicates: 'overdue' is met when input > within_minutes (strict); 'within' is met when input <= within_minutes."
              },
              "severity": {
                "type": "string",
                "enum": ["normal", "watch", "urgent", "critical"],
                "description": "Optional severity override applied when the predicate is met (currently used by temporal; defaults to 'urgent' when met and omitted)."
              },
              "rationale": {
                "type": "string",
                "description": "Human-readable rationale rendered from the predicate AST (validated by Gate C)."
              }
            }
          }
        }
      }
    },
    "states": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "order", "is_terminal"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "description": "Unique state identifier within the pathway."
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "Human-readable state name."
          },
          "order": {
            "type": "integer",
            "minimum": 0,
            "description": "Ordinal position (0-indexed)."
          },
          "is_terminal": {
            "type": "boolean",
            "description": "Whether this is a terminal (exit) state."
          },
          "description": {
            "type": "string"
          },
          "auto_advance": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "when": {
                "type": "string",
                "enum": ["all_criteria_met", "any_criterion_fires", "timer_expired"],
                "description": "Condition for automatic state advancement."
              },
              "target_state": {
                "type": "string",
                "description": "State ID to advance to."
              },
              "timer_minutes": {
                "type": "integer",
                "minimum": 1,
                "description": "Timer duration in minutes (for timer_expired)."
              }
            }
          }
        }
      }
    },
    "suppression": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cooldown_minutes": {
          "type": "integer",
          "minimum": 0,
          "description": "Minimum minutes between repeated firings of the same alert for the same patient."
        },
        "rate_limit_per_hour": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum firings per hour per patient."
        },
        "dedup_key": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Fields used to deduplicate alerts (e.g., ['mpi_id', 'criteria_id'])."
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "guideline": {
          "type": "string",
          "description": "Clinical practice guideline citation."
        },
        "doi": {
          "type": "string",
          "description": "DOI reference for supporting evidence."
        },
        "recommendations": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Clinical recommendations triggered by this alert."
        }
      }
    }
  }
}
