# =============================================================================
# Intensicare — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# =============================================================================

# ── Environment ──────────────────────────────────────────────────────────────
ENVIRONMENT=development       # development | testing | staging | production
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR | CRITICAL
DEBUG=false

# ── Security / Secrets ──────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production           # JWT signing key (also used as JWT_SECRET_KEY)
JWT_SECRET_KEY=change-me-in-production       # Alias for SECRET_KEY (both are equivalent)
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# ── Encryption Keys ─────────────────────────────────────────────────────────
# KMS / Encryption key ARN for envelope encryption (pgcrypto + KMS)
ENCRYPTION_KEY_ARN=                          # AWS KMS CMK ARN (alias for KMS_CMK_ARN)
KMS_CMK_ARN=                                 # AWS KMS Customer Master Key ARN
KMS_REGION=us-east-1
KMS_DEK_SIZE_BYTES=32

# ── API Server ──────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
API_WORKERS=1
CORS_ORIGINS=["http://localhost:3000"]

# ── PostgreSQL / TimescaleDB ────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=intensicare
POSTGRES_PASSWORD=intensicare_dev
POSTGRES_DB=intensicare
POSTGRES_MIN_CONNECTIONS=2
POSTGRES_MAX_CONNECTIONS=10

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=                              # Required in production

# ── ARQ Worker ──────────────────────────────────────────────────────────────
ARQ_CONCURRENCY=4                             # Number of concurrent ARQ worker jobs
ARQ_POLL_INTERVAL=1                           # Queue poll interval in seconds

# ── AWS IAM Identity Center (Fase 3) ────────────────────────────────────────
IAM_ENABLED=false
IAM_IDENTITY_STORE_ARN=
IAM_APPLICATION_ARN=
IAM_OIDC_ISSUER=
IAM_CLIENT_ID=
IAM_ROLE_ARN=
IAM_REGION=us-east-1

# ── Lake Formation / ABAC ───────────────────────────────────────────────────
LAKE_FORMATION_DATA_CATALOG_ID=
LAKE_FORMATION_DATABASE_PREFIX=intensicare

# ── FHIR / HAPI FHIR ────────────────────────────────────────────────────────
FHIR_BASE_URL=
FHIR_AUTH_TOKEN=

# ── MPI (Master Patient Index) ──────────────────────────────────────────────
MPI_BASE_URL=
MPI_AUTH_TOKEN=

# ── Watchdog & Staleness ────────────────────────────────────────────────────
WATCHDOG_TIMEOUT_SECONDS=30
STALENESS_ALERT_MINUTES=15

# ── Athena (optional) ───────────────────────────────────────────────────────
ATHENA_ENABLED=false
ATHENA_DATABASE=intensicare
ATHENA_OUTPUT_LOCATION=
ATHENA_WORKGROUP=intensicare
ATHENA_REGION=us-east-1
