# =============================================================================
# Intensicare — Variáveis de Ambiente (Desenvolvimento Local)
# Copie este arquivo para .env e ajuste conforme necessário.
# =============================================================================

# ---------------------------------------------------------------------------
# Ambiente
# ---------------------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=DEBUG
DEBUG=true
SECRET_KEY=dev-secret-key-change-in-production

# ---------------------------------------------------------------------------
# API
# ---------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_WORKERS=1

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
# Comma-separated list of allowed origins. Use "*" for development only.
CORS_ORIGINS=*

# ---------------------------------------------------------------------------
# JWT / Auth (fallback para dev/test — produção usa IAM IC)
# ---------------------------------------------------------------------------
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# ---------------------------------------------------------------------------
# AWS IAM Identity Center — SSO (Fase 3 / WO-037)
# ---------------------------------------------------------------------------
# Quando IAM_ENABLED=true, a validação de tokens IAM IC substitui JWT local.
IAM_ENABLED=false
IAM_IDENTITY_STORE_ARN=
IAM_APPLICATION_ARN=
IAM_OIDC_ISSUER=
IAM_CLIENT_ID=
IAM_ROLE_ARN=
IAM_REGION=us-east-1

# ---------------------------------------------------------------------------
# Lake Formation / ABAC (Fase 3 / WO-037)
# ---------------------------------------------------------------------------
LAKE_FORMATION_DATA_CATALOG_ID=
LAKE_FORMATION_DATABASE_PREFIX=intensicare

# ---------------------------------------------------------------------------
# KMS — hierarquia de chaves por tenant (Fase 3 / WO-037)
# ---------------------------------------------------------------------------
KMS_CMK_ARN=
KMS_REGION=us-east-1
KMS_DEK_SIZE_BYTES=32

# ---------------------------------------------------------------------------
# FHIR (HAPI FHIR / AMH Data Platform)
# ---------------------------------------------------------------------------
# Base URL vazia desabilita enriquecimento FHIR.
FHIR_BASE_URL=
FHIR_AUTH_TOKEN=

# ---------------------------------------------------------------------------
# MPI (Master Patient Index)
# ---------------------------------------------------------------------------
# Base URL vazia desabilita sincronização externa.
MPI_BASE_URL=
MPI_AUTH_TOKEN=

# ---------------------------------------------------------------------------
# PostgreSQL + TimescaleDB
# ---------------------------------------------------------------------------
POSTGRES_USER=intensicare
POSTGRES_PASSWORD=intensicare_dev
POSTGRES_DB=intensicare
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_MIN_CONNECTIONS=2
POSTGRES_MAX_CONNECTIONS=10

# Connection string async
DATABASE_URL=postgresql+asyncpg://intensicare:intensicare_dev@localhost:5432/intensicare

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# TimescaleDB (extensões)
# ---------------------------------------------------------------------------
TIMESCALEDB_TELEMETRY=off

# ---------------------------------------------------------------------------
# Watchdog / Dead-man's switch (INV-5)
# ---------------------------------------------------------------------------
# Janela para ping externo no /health. Se expirar, watchdog dispara alerta.
WATCHDOG_TIMEOUT_SECONDS=30
# Limite de inatividade: se nenhum score clínico for computado neste
# intervalo (minutos), o monitor de staleness dispara um alerta.
STALENESS_ALERT_MINUTES=15

# ---------------------------------------------------------------------------
# Athena (opcional — desabilitado por padrão)
# ---------------------------------------------------------------------------
ATHENA_ENABLED=false
ATHENA_DATABASE=intensicare
ATHENA_OUTPUT_LOCATION=
ATHENA_WORKGROUP=intensicare
ATHENA_REGION=us-east-1

# ---------------------------------------------------------------------------
# Observabilidade (opcional em dev)
# ---------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=intensicare-api

# ---------------------------------------------------------------------------
# AWS (para Secrets Manager e outros serviços)
# ---------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
