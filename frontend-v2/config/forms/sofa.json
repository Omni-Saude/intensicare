{
  "id": "sofa",
  "title": "Sequential Organ Failure Assessment (SOFA)",
  "description": "Avaliação sequencial de falência orgânica. Escore total: 0 (melhor) a 24 (pior).",
  "groups": [
    {
      "title": "Sistemas SOFA (0–4 cada)",
      "fields": [
        {
          "name": "sofaRespiratorio",
          "label": "Respiratório — Relação PaO₂/FiO₂",
          "type": "select",
          "required": true,
          "placeholder": "Selecionar escore...",
          "options": [
            { "value": "0", "label": "0 — PaO₂/FiO₂ ≥ 400" },
            { "value": "1", "label": "1 — PaO₂/FiO₂ 300–399" },
            { "value": "2", "label": "2 — PaO₂/FiO₂ 200–299" },
            { "value": "3", "label": "3 — PaO₂/FiO₂ 100–199 com suporte ventilatório" },
            { "value": "4", "label": "4 — PaO₂/FiO₂ < 100 com suporte ventilatório" }
          ],
          "hint": "Utilizar a pior relação PaO₂/FiO₂ nas últimas 24h."
        },
        {
          "name": "sofaCoagulacao",
          "label": "Coagulação — Plaquetas (×10³/mm³)",
          "type": "select",
          "required": true,
          "placeholder": "Selecionar escore...",
          "options": [
            { "value": "0", "label": "0 — Plaquetas ≥ 150" },
            { "value": "1", "label": "1 — Plaquetas 100–149" },
            { "value": "2", "label": "2 — Plaquetas 50–99" },
            { "value": "3", "label": "3 — Plaquetas 20–49" },
            { "value": "4", "label": "4 — Plaquetas < 20" }
          ],
          "hint": "Utilizar a pior contagem de plaquetas nas últimas 24h."
        },
        {
          "name": "sofaHepatico",
          "label": "Hepático — Bilirrubina (mg/dL)",
          "type": "select",
          "required": true,
          "placeholder": "Selecionar escore...",
          "options": [
            { "value": "0", "label": "0 — Bilirrubina < 1,2" },
            { "value": "1", "label": "1 — Bilirrubina 1,2–1,9" },
            { "value": "2", "label": "2 — Bilirrubina 2,0–5,9" },
            { "value": "3", "label": "3 — Bilirrubina 6,0–11,9" },
            { "value": "4", "label": "4 — Bilirrubina ≥ 12,0" }
          ],
          "hint": "Utilizar o pior valor de bilirrubina total nas últimas 24h."
        },
        {
          "name": "sofaCardiovascular",
          "label": "Cardiovascular — PAM / Vasopressores",
          "type": "select",
          "required": true,
          "placeholder": "Selecionar escore...",
          "options": [
            { "value": "0", "label": "0 — PAM ≥ 70 mmHg" },
            { "value": "1", "label": "1 — PAM < 70 mmHg" },
            { "value": "2", "label": "2 — Dopamina ≤ 5 ou Dobutamina (qualquer dose)" },
            { "value": "3", "label": "3 — Dopamina > 5 ou Noradrenalina ≤ 0,1" },
            { "value": "4", "label": "4 — Dopamina > 15 ou Noradrenalina > 0,1" }
          ],
          "hint": "Doses de vasopressores em µg/kg/min. PAM = Pressão Arterial Média."
        },
        {
          "name": "sofaNeurologico",
          "label": "Neurológico — Escala de Coma de Glasgow",
          "type": "select",
          "required": true,
          "placeholder": "Selecionar escore...",
          "options": [
            { "value": "0", "label": "0 — Glasgow 15" },
            { "value": "1", "label": "1 — Glasgow 13–14" },
            { "value": "2", "label": "2 — Glasgow 10–12" },
            { "value": "3", "label": "3 — Glasgow 6–9" },
            { "value": "4", "label": "4 — Glasgow < 6" }
          ],
          "hint": "Utilizar o pior Glasgow nas últimas 24h (sem sedação)."
        },
        {
          "name": "sofaRenal",
          "label": "Renal — Creatinina (mg/dL) / Débito Urinário",
          "type": "select",
          "required": true,
          "placeholder": "Selecionar escore...",
          "options": [
            { "value": "0", "label": "0 — Creatinina < 1,2" },
            { "value": "1", "label": "1 — Creatinina 1,2–1,9" },
            { "value": "2", "label": "2 — Creatinina 2,0–3,4" },
            { "value": "3", "label": "3 — Creatinina 3,5–4,9 ou débito < 500 mL/dia" },
            { "value": "4", "label": "4 — Creatinina ≥ 5,0 ou débito < 200 mL/dia" }
          ],
          "hint": "Utilizar o pior valor de creatinina nas últimas 24h."
        }
      ]
    },
    {
      "title": "Observações",
      "fields": [
        {
          "name": "sofaNote",
          "label": "Observação Clínica",
          "type": "string",
          "required": false,
          "placeholder": "Observações adicionais sobre a avaliação SOFA..."
        }
      ]
    }
  ]
}
