{
  "id": "rass",
  "title": "Richmond Agitation-Sedation Scale (RASS)",
  "description": "Avaliação do nível de sedação e agitação do paciente na UTI.",
  "groups": [
    {
      "title": "Escore RASS",
      "fields": [
        {
          "name": "rassScore",
          "label": "Escore RASS (-5 a +4)",
