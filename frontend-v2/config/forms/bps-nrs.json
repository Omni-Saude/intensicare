{
  "id": "bps-nrs",
  "title": "Avaliação de Dor: BPS / NRS",
  "description": "Escalas de avaliação de dor para pacientes na UTI (BPS: 3-12, NRS: 0-10).",
  "groups": [
    {
      "title": "Escores de Dor",
      "fields": [
        {
          "name": "bpsScore",
          "label": "Behavioral Pain Scale (BPS) — 3 a 12",
          "type": "select",
          "required": false,
          "placeholder": "Selecionar escore BPS...",
          "options": [
            { "value": "3", "label": "3 — Sem dor" },
            { "value": "4", "label": "4 — Dor leve" },
            { "value": "5", "label": "5 — Dor leve" },
            { "value": "6", "label": "6 — Dor moderada" },
            { "value": "7", "label": "7 — Dor moderada" },
            { "value": "8", "label": "8 — Dor moderada" },
            { "value": "9", "label": "9 — Dor intensa" },
            { "value": "10", "label": "10 — Dor intensa" },
            { "value": "11", "label": "11 — Dor intensa" },
            { "value": "12", "label": "12 — Dor máxima" }
          ],
          "hint": "Escore BPS: 3-5 (sem/leve), 6-8 (moderada), 9-12 (intensa)."
        },
        {
          "name": "nrsScore",
          "label": "Numeric Rating Scale (NRS) — 0 a 10",
          "type": "select",
          "required": false,
          "placeholder": "Selecionar escore NRS...",
          "options": [
            { "value": "0", "label": "0 — Sem dor" },
            { "value": "1", "label": "1 — Dor leve" },
            { "value": "2", "label": "2 — Dor leve" },
            { "value": "3", "label": "3 — Dor leve" },
            { "value": "4", "label": "4 — Dor moderada" },
            { "value": "5", "label": "5 — Dor moderada" },
            { "value": "6", "label": "6 — Dor moderada" },
            { "value": "7", "label": "7 — Dor intensa" },
            { "value": "8", "label": "8 — Dor intensa" },
            { "value": "9", "label": "9 — Dor intensa" },
            { "value": "10", "label": "10 — Dor máxima" }
          ],
          "hint": "Escore NRS: 0-3 (leve), 4-6 (moderada), 7-10 (intensa)."
        }
      ]
    },
    {
      "title": "Observações",
      "fields": [
        {
          "name": "painNote",
          "label": "Observação Clínica",
          "type": "string",
          "required": false,
          "placeholder": "Localização, características da dor..."
        }
      ]
    }
  ],
  "validation": {
    "atLeastOne": ["bpsScore", "nrsScore"]
  }
}
