{
  "id": "lpp",
  "title": "Avaliação de Risco para Lesão por Pressão (NPUAP / Braden)",
  "description": "Avaliação do risco de desenvolvimento de lesão por pressão em pacientes internados na UTI.",
  "groups": [
    {
      "title": "Escala de Braden",
      "fields": [
        {
          "name": "bradenPercepcaoSensorial",
          "label": "Percepção Sensorial",
          "type": "select",
          "required": true,
          "placeholder": "Selecionar...",
          "options": [
            { "value": "1", "label": "1 — Completamente Limitada" },
            { "value": "2", "label": "2 — Muito Limitada" },
            { "value": "3", "label": "3 — Levemente Limitada" },
            { "value": "4", "label": "4 — Nenhuma Limitação" }
          ],
          "hint": "Capacidade de responder significativamente à pressão relacionada ao desconforto."
        },
        {
          "name": "bradenUmidade",
          "label": "Umidade",
          "type": "select",
          "required": true,
          "placeholder": "Selecionar...",
          "options": [
            { "value": "1", "label": "1 — Constantemente Úmida" },
            { "value": "2", "label": "2 — Muito Úmida" },
            { "value": "3", "label": "3 — Ocasionalmente Úmida" },
            { "value": "4", "label": "4 — Raramente Úmida" }
          ],
          "hint": "Grau de exposição da pele à umidade."
        },
        {
          "name": "bradenAtividade",
          "label": "Atividade",
          "type": "select",
          "required": true,
          "placeholder": "Selecionar...",
          "options": [
            { "value": "1", "label": "1 — Acamado" },
            { "value": "2", "label": "2 — Restrito à Cadeira" },
            { "value": "3", "label": "3 — Deambula Ocasionalmente" },
            { "value": "4", "label": "4 — Deambula Frequentemente" }
          ],
          "hint": "Grau de atividade física."
        },
        {
          "name": "bradenMobilidade",
          "label": "Mobilidade",
          "type": "select",
          "required": true,
          "placeholder": "Selecionar...",
          "options": [
            { "value": "1", "label": "1 — Totalmente Imóvel" },
            { "value": "2", "label": "2 — Bastante Limitada" },
            { "value": "3", "label": "3 — Levemente Limitada" },
            { "value": "4", "label": "4 — Nenhuma Limitação" }
          ],
          "hint": "Capacidade de mudar e controlar a posição do corpo."
        },
        {
          "name": "bradenNutricao",
          "label": "Nutrição",
          "type": "select",
          "required": true,
          "placeholder": "Selecionar...",
          "options": [
            { "value": "1", "label": "1 — Muito Pobre" },
            { "value": "2", "label": "2 — Provavelmente Inadequada" },
            { "value": "3", "label": "3 — Adequada" },
            { "value": "4", "label": "4 — Excelente" }
          ],
          "hint": "Padrão usual de ingestão alimentar."
        },
        {
          "name": "bradenFriccao",
          "label": "Fricção e Cisalhamento",
          "type": "select",
          "required": true,
          "placeholder": "Selecionar...",
          "options": [
            { "value": "1", "label": "1 — Problema" },
            { "value": "2", "label": "2 — Problema Potencial" },
            { "value": "3", "label": "3 — Nenhum Problema" }
          ],
          "hint": "Necessidade de assistência para movimentação e deslizamento no leito."
        }
      ]
    },
    {
      "title": "Estadiamento da Lesão (se presente)",
      "collapsible": true,
      "defaultOpen": false,
      "fields": [
        {
          "name": "lppEstadiamento",
          "label": "Estadiamento NPUAP",
          "type": "select",
          "required": false,
          "placeholder": "Selecionar estágio...",
          "options": [
            { "value": "0", "label": "Nenhuma lesão presente" },
            { "value": "1", "label": "Estágio 1 — Eritema não branqueável" },
            { "value": "2", "label": "Estágio 2 — Perda parcial da pele (bolha/abrasão)" },
            { "value": "3", "label": "Estágio 3 — Perda total da pele (tecido subcutâneo visível)" },
            { "value": "4", "label": "Estágio 4 — Perda total com exposição óssea/tendínea" },
            { "value": "5", "label": "Não Classificável — Profundidade desconhecida" },
            { "value": "6", "label": "Tissular Profunda — Suspeita de lesão profunda" }
          ],
          "hint": "Classificar conforme diretriz NPUAP vigente."
        },
        {
          "name": "lppLocalizacao",
          "label": "Localização da Lesão",
          "type": "string",
          "required": false,
          "placeholder": "Ex.: Sacral, calcâneo, trocantérica..."
        }
      ]
    },
    {
      "title": "Observações",
      "fields": [
        {
          "name": "lppNote",
          "label": "Observação Clínica",
          "type": "string",
          "required": false,
          "placeholder": "Medidas preventivas, superfícies de alívio, curativos..."
        }
      ]
    }
  ]
}
