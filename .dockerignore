# =============================================================================
# Intensicare — .dockerignore
# Keep the Docker build context lean and avoid leaking secrets.
# =============================================================================

# Version control
.git
.gitignore
.gitattributes

# Python virtual environment and caches
.venv
venv
env
__pycache__
*.pyc
*.pyo
*.egg-info
*.egg
dist
build
*.so

# Node / Frontend
node_modules
.next
.npm
.cache

# Environment files — DO NOT leak secrets into the image
.env
.env.*
!.env.example

# Secrets and keys
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx

# Test coverage and reports
coverage.xml
.coverage
htmlcov
.pytest_cache
.mypy_cache
.ruff_cache
.tox

# IDE and editor
.vscode
.idea
*.swp
*.swo
*~
.project
.classpath
.settings

# Documentation (except README)
*.md
!README.md
docs/

# Source code for frontend tests (production image only ships dist/)
frontend/src/
frontend/public/
tests/

# OS junk
.DS_Store
Thumbs.db

# CI / local tooling
.github/
